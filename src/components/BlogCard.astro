---
export interface Props {
    title: string;
    slug: string;
    date: Date;
    year: number;
    month: string;
    featured?: boolean;
    image?: string;
    imageAlt?: string;
    authorName?: string;
    authorAvatar?: string;
}

const {
    title,
    slug,
    date,
    year,
    month,
    featured,
    image,
    imageAlt,
    authorName,
    authorAvatar,
} = Astro.props;

const postUrl = `/blog/${year}/${month}/${slug}`;

const formattedDate = date.toLocaleDateString("en-US", {
    year: "numeric",
    month: "long",
    day: "numeric",
});
---

<article class="blog-card" class:list={{ featured: featured }}>
    <a href={postUrl} class="blog-card-link">
        {
            image && (
                <div class="card-image">
                    <img src={image} alt={imageAlt ?? ""} loading="lazy" />
                </div>
            )
        }

        <div class="card-body">
            <div class="card-meta">
                <time datetime={date.toISOString()}>{formattedDate}</time>

                {featured && <span class="featured-badge">Featured</span>}
            </div>

            <h2 class="card-title">{title}</h2>

            <div class="card-footer">
                {
                    authorName && (
                        <div class="card-author-row">
                            <img
                                class="card-avatar"
                                src={authorAvatar}
                                alt=""
                                width="28"
                                height="28"
                                loading="lazy"
                            />
                            <span class="card-author">{authorName}</span>
                        </div>
                    )
                }
            </div>
        </div>
    </a>
</article>

<style>
    .blog-card {
        background-color: var(--background-secondary);
        border: 1px solid var(--background-tetiary);
        border-radius: 12px;
        overflow: hidden;
        transition:
            border-color 0.2s ease,
            transform 0.2s ease,
            box-shadow 0.2s ease;
    }

    .blog-card:hover {
        border-color: var(--colors-accent);
        transform: translateY(-2px);
        box-shadow: 0 8px 24px rgba(0, 0, 0, 0.2);
    }

    .blog-card.featured {
        border-color: var(--colors-accent);
        position: relative;
    }

    .blog-card-link {
        display: flex;
        flex-direction: column;
        text-decoration: none;
        color: inherit;
        height: 100%;
    }

    .card-image {
        width: 100%;
        aspect-ratio: 16 / 9;
        overflow: hidden;
        background-color: var(--background-tetiary);
    }

    .card-image img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.3s ease;
    }

    .blog-card:hover .card-image img {
        transform: scale(1.05);
    }

    .card-body {
        padding: 24px;
        display: flex;
        flex-direction: column;
        gap: 12px;
        flex: 1;
    }

    .card-meta {
        display: flex;
        align-items: center;
        gap: 12px;
        font-size: 13px;
        color: var(--text-secondary);
    }

    .featured-badge {
        background-color: var(--colors-accent);
        color: var(--text-primary);
        padding: 2px 8px;
        border-radius: 4px;
        font-size: 11px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.05em;
    }

    .card-title {
        margin: 0;
        font-size: 20px;
        font-weight: 600;
        color: var(--text-primary);
        line-height: 1.3;
    }

    .card-footer {
        margin-top: auto;
        display: flex;
        flex-direction: column;
        gap: 12px;
    }

    .card-author-row {
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .card-avatar {
        width: 28px;
        height: 28px;
        border-radius: 50%;
        object-fit: cover;
        flex-shrink: 0;
        background-color: var(--background-tetiary);
    }

    .card-author {
        font-size: 13px;
        color: var(--colors-accent-light);
        font-weight: 500;
    }
</style>
