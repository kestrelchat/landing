---
import "../styles/fonts";
---

<style is:global>
    @import "normalize.css";

    :root {
        --background-primary: #13131e;
        --background-secondary: #171625;
        --background-tetiary: #202248;

        --text-primary: #edeef0;
        --text-secondary: #b0b4ba;

        --colors-accent: #6e6ade;
        --colors-accent-light: #9b9ef0;
        --colors-accent-dark: #5958b1;
        --colors-red: #e5484d;
        --colors-red-light: #eb8e90;
        --colors-red-dark: #b54548;
        --colors-orange: #f76b15;
        --colors-orange-light: #ec9455;
        --colors-orange-dark: #a35829;
        --colors-yellow: #ffe629;
        --colors-yellow-light: #ffe770;
        --colors-yellow-dark: #836a21;
        --colors-green: #30a46c;
        --colors-green-light: #8eceaa;
        --colors-green-dark: #2f7c57;
        --colors-cyan: #00a2c7;
        --colors-cyan-light: #7dcedc;
        --colors-cyan-dark: #11809c;
        --colors-blue: #0090ff;
        --colors-blue-light: #5eb1ef;
        --colors-blue-dark: #2870bd;
        --colors-indigo: #3e63dd;
        --colors-indigo-light: #8da4ef;
        --colors-indigo-dark: #435db1;
        --colors-violet: #6e56cf;
        --colors-violet-light: #aa99ec;
        --colors-violet-dark: #6958ad;
        --colors-pink: #d6409f;
        --colors-pink-light: #dd93c2;
        --colors-pink-dark: #a84885;
    }

    :root.light {
        --background-primary: #fcfcfd;
        --background-secondary: #f9f9fb;
        --background-tetiary: #f0f0f3;

        --text-primary: #1c2024;
        --text-secondary: #60646c;
    }

    * {
        transition:
            background-color var(--transition-theme),
            color var(--transition-theme),
            border-color var(--transition-theme);
    }

    html,
    body {
        margin: 0;
        padding: 0;
        background-color: var(--background-secondary);
        font-family: "DM Sans", sans-serif;
        font-optical-sizing: auto;
        font-style: normal;
        color: var(--text-primary);
        overflow-x: hidden;
    }

    h1 {
        font-weight: 700;
        line-height: 1.1;
    }

    h2 {
        font-weight: 600;
        line-height: 1.2;
    }

    h3 {
        font-weight: 600;
        line-height: 1.25;
    }

    h4 {
        font-weight: 600;
        line-height: 1.3;
    }

    h5 {
        font-weight: 500;
        line-height: 1.35;
    }

    h6 {
        font-weight: 500;
        line-height: 1.4;
    }

    p {
        font-weight: 400;
    }
</style>
